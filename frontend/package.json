    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@xyflow/react": "^12.9.3",
    "ajv": "^8.12.0",
    "antd": "^5.11.1",
    "axios": "^1.6.0",
    "cytoscape": "^3.26.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.17.0",
