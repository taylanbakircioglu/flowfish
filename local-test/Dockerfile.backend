# Flowfish Backend - Local Test Dockerfile
# This Dockerfile is for local Kubernetes testing only
# Production uses backend/Dockerfile

FROM python:3.11-slim as base

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    make \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 -s /bin/bash appuser

WORKDIR /app

# Copy requirements and filter out grpcio (we'll install our own version)
COPY backend/requirements.txt /tmp/requirements.txt
RUN grep -v "^grpcio" /tmp/requirements.txt > requirements.txt

# Install base requirements first
RUN pip install --no-cache-dir -r requirements.txt

# Install compatible protobuf and grpcio for proto generation
# grpcio-tools generates code for protobuf 5.x, so we need protobuf 5.x
RUN pip install --no-cache-dir "protobuf>=5.28.0" "grpcio>=1.60.0" "grpcio-tools>=1.60.0"

# Copy proto files and generate Python code
COPY proto/ ./proto_source/
RUN mkdir -p proto && \
    python -m grpc_tools.protoc \
    -I./proto_source \
    --python_out=./proto \
    --grpc_python_out=./proto \
    proto_source/*.proto && \
    touch proto/__init__.py

# Copy and run the import fixer script
COPY local-test/fix_proto_imports.py /tmp/fix_proto_imports.py
RUN python /tmp/fix_proto_imports.py

# Backup fixed proto directory
RUN mv proto /tmp/proto_fixed

# Copy source code
COPY backend/ .

# Restore fixed proto directory (override the old one from backend/)
RUN rm -rf proto && mv /tmp/proto_fixed proto

# Apply local patches
COPY local-test/patches/ /tmp/patches/
RUN cp /tmp/patches/postgresql_fix.py database/postgresql.py 2>/dev/null || true && \
    cp /tmp/patches/cluster_info_service_fix.py services/cluster_info_service.py 2>/dev/null || true && \
    cp /tmp/patches/workloads_fix.py routers/workloads.py 2>/dev/null || true && \
    cp /tmp/patches/analyses_fix.py routers/analyses.py 2>/dev/null || true && \
    cp /tmp/patches/clusters_fix.py routers/clusters.py 2>/dev/null || true

# Disable auth for local testing (analyses endpoints)
RUN sed -i 's/current_user: dict = Depends(get_current_user)/# current_user disabled for local/g' routers/analyses.py || true

# Patch neo4j.py for optional Neo4j (local testing)
RUN sed -i 's/neo4j_driver = get_neo4j_driver()/try:\n    neo4j_driver = get_neo4j_driver()\nexcept Exception as e:\n    import structlog\n    structlog.get_logger().warning("Neo4j not available", error=str(e))\n    neo4j_driver = None/' database/neo4j.py || true

RUN chown -R appuser:0 /app && chmod -R g=u /app

USER appuser

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]

